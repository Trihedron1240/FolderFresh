<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FolderFresh.Components.SetupAdvisorPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1C1C1C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="24,16" Background="#252525">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock x:Name="HeaderTitle"
                           Text="Smart Setup"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock x:Name="HeaderSubtitle"
                           Text="Analyze a folder and generate starter categories and rules you can review before saving."
                           FontSize="13"
                           Foreground="#999999"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8"
                    Click="CloseButton_Click">
                <TextBlock Text="&#xE711;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="#999999"/>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24">
            <StackPanel MaxWidth="760" HorizontalAlignment="Left" Spacing="16">
                <Border Background="#252525" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="FolderLabel"
                                       Text="Folder"
                                       FontSize="12"
                                       Foreground="#999999"/>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#2D2D2D"
                                        BorderBrush="#333333"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,10">
                                    <TextBlock x:Name="FolderPathText"
                                               Text="Select Folder..."
                                               Foreground="White"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <Button x:Name="BrowseButton"
                                        Grid.Column="1"
                                        Background="#2D2D2D"
                                        Foreground="#B5BAC1"
                                        Padding="14,10"
                                        CornerRadius="8"
                                        Click="BrowseButton_Click">
                                    <TextBlock x:Name="BrowseButtonText"
                                               Text="Browse"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ToggleSwitch x:Name="IncludeSubfoldersToggle"
                                          Grid.Column="0"
                                          Header="Include subfolders"
                                          OnContent=""
                                          OffContent=""
                                          Toggled="IncludeSubfoldersToggle_Toggled"/>

                            <StackPanel Grid.Column="1" Width="140" Spacing="6">
                                <TextBlock x:Name="MaxFilesLabel"
                                           Text="Max files to scan"
                                           FontSize="12"
                                           Foreground="#999999"/>
                                <TextBox x:Name="MaxFilesTextBox"
                                         Text="500"
                                         Height="40"
                                         Background="#2D2D2D"
                                         BorderBrush="#333333"
                                         CornerRadius="8"
                                         TextChanged="MaxFilesTextBox_TextChanged"/>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="AnalyzeButton"
                                Click="AnalyzeButton_Click"
                                Background="#5865F2"
                                Foreground="White"
                                Padding="16,10"
                                CornerRadius="8"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="AnalyzeButtonText"
                                       Text="Analyze Folder"
                                       FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Background="#252525" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="StatusLabel"
                                   Text="Status"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="StatusText"
                                   Text="Select a folder and analyze it to generate starter categories and rules."
                                   FontSize="13"
                                   Foreground="#999999"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="#252525" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="CategoriesLabel"
                                   Text="Suggested Categories"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="NoCategoriesText"
                                   Text="No category suggestions yet."
                                   FontSize="13"
                                   Foreground="#666666"/>
                        <StackPanel x:Name="CategoriesPanel" Spacing="10"/>
                    </StackPanel>
                </Border>

                <Border Background="#252525" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="RulesLabel"
                                   Text="Suggested Rules"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="NoRulesText"
                                   Text="No rule suggestions yet."
                                   FontSize="13"
                                   Foreground="#666666"/>
                        <StackPanel x:Name="RulesPanel" Spacing="10"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#252525" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Margin="0,0,12,0"
                        Background="#333333"
                        Foreground="White"
                        Padding="20,10"
                        CornerRadius="6"
                        Click="CloseButton_Click">
                    <TextBlock x:Name="CloseButtonText"
                               Text="Close"/>
                </Button>

                <Button x:Name="ApplyButton"
                        Grid.Column="2"
                        Background="#5865F2"
                        Foreground="White"
                        Padding="20,10"
                        CornerRadius="6"
                        Click="ApplyButton_Click">
                    <TextBlock x:Name="ApplyButtonText"
                               Text="Apply Selected Suggestions"
                               FontWeight="SemiBold"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
