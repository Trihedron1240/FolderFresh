<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FolderFresh.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:FolderFresh.Components"
    Background="#111214"
    RequestedTheme="Dark">

    <Grid Background="#111214">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#17181A">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1" Padding="8,12,8,0" Spacing="4">
                <Button x:Name="NavItem_Home" Tag="home" Content="Home" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="#232428" Foreground="White" BorderBrush="Transparent" />
                <Button x:Name="NavItem_Folders" Tag="folders" Content="Folders" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B5BAC1" BorderBrush="Transparent" />
                <Button x:Name="NavItem_Rules" Tag="rules" Content="Rules" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B5BAC1" BorderBrush="Transparent" />
                <Button x:Name="NavItem_Categories" Tag="categories" Content="Categories" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B5BAC1" BorderBrush="Transparent" />
                <Button x:Name="NavItem_Profiles" Tag="profiles" Content="Profiles" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B5BAC1" BorderBrush="Transparent" />
                <Button x:Name="NavItem_Snapshots" Tag="snapshots" Content="Snapshots" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B5BAC1" BorderBrush="Transparent" />
            </StackPanel>

            <Button
                x:Name="NavItem_Settings"
                Grid.Row="2"
                Margin="8,0,8,12"
                Tag="settings"
                Content="Settings"
                Click="NavButton_Click"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                Foreground="#B5BAC1"
                BorderBrush="Transparent" />
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="16,0" Background="#1E1F22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Foreground="#5865F2" Glyph="&#xE8B5;" />
                    <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Text="FolderFresh 3.0.3" />
                </StackPanel>

                <Button Grid.Column="2" Padding="12,6" VerticalAlignment="Center" Background="#232428" BorderBrush="Transparent" Click="FolderSelector_Click" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Foreground="#B5BAC1" Glyph="&#xE8B7;" />
                        <TextBlock x:Name="FolderPathText" VerticalAlignment="Center" FontSize="12" Foreground="#B5BAC1" Text="Select Folder..." />
                        <FontIcon FontSize="10" Foreground="#949BA4" Glyph="&#xE70D;" />
                    </StackPanel>
                </Button>
            </Grid>

            <Frame x:Name="ContentFrame" Grid.Row="1" Visibility="Collapsed" />

            <Grid x:Name="HomeContent" Grid.Row="1" Padding="40,24,40,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="CurrentLabel" Grid.Row="0" Margin="0,0,0,8" CharacterSpacing="50" FontSize="10" FontWeight="SemiBold" Foreground="#949BA4" Text="CURRENT" />

                    <Border Grid.Row="1" MinHeight="380" Background="#1E1F22" BorderBrush="#2B2D31" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <StackPanel x:Name="CurrentEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <FontIcon HorizontalAlignment="Center" FontSize="48" Foreground="#3F4147" Glyph="&#xE838;" />
                                <TextBlock x:Name="SelectFolderToPreviewText" FontSize="14" Foreground="#6D6F78" Text="Select a folder to preview" />
                            </StackPanel>

                            <components:FileExplorerPanel
                                x:Name="CurrentFilesPanel"
                                Background="Transparent"
                                FileOpened="CurrentFilesPanel_FileOpened"
                                FolderOpened="CurrentFilesPanel_FolderOpened"
                                SelectionChanged="CurrentFilesPanel_SelectionChanged"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                </Grid>

                <TextBlock Grid.Column="1" Margin="16,0" VerticalAlignment="Center" FontSize="24" Foreground="#5865F2" Text=">" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="AfterLabel" Grid.Row="0" Margin="0,0,0,8" CharacterSpacing="50" FontSize="10" FontWeight="SemiBold" Foreground="#949BA4" Text="AFTER" />

                    <Border Grid.Row="1" MinHeight="380" Background="#1E1F22" BorderBrush="#2B2D31" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <StackPanel x:Name="AfterEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <FontIcon HorizontalAlignment="Center" FontSize="48" Foreground="#3F4147" Glyph="&#xE734;" />
                                <TextBlock x:Name="OrganizedPreviewText" FontSize="14" Foreground="#6D6F78" Text="Organized preview" />
                            </StackPanel>

                            <components:FileExplorerPanel
                                x:Name="AfterFilesPanel"
                                Background="Transparent"
                                EmptyStateText="No files to organize"
                                FolderOpened="AfterFilesPanel_FolderOpened"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <StackPanel x:Name="BottomActionPanel" Grid.Row="2" Margin="0,8,0,16" HorizontalAlignment="Center" Spacing="8">
                <Button
                    x:Name="OrganizeButton"
                    Width="200"
                    Height="44"
                    Background="#5865F2"
                    Click="OrganizeButton_Click"
                    Content="Organize Now"
                    CornerRadius="10"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White" />

                <HyperlinkButton
                    x:Name="UndoButton"
                    HorizontalAlignment="Center"
                    Click="UndoButton_Click"
                    Content="Undo"
                    FontSize="11"
                    Foreground="#949BA4"
                    Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
